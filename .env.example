# === SportScout AI Environment Variables ===

# Anthropic API Key (required for Claude Sonnet planner)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Sportradar NBA API Key (required for live data)
SPORTRADAR_API_KEY=xxxx

# Model Config
# Planner uses Sonnet 4.6 (hardcoded — needs reasoning capability)
# Narrator model is configurable — Haiku 4.5 is default (4x cheaper for summaries)
NARRATOR_MODEL=claude-haiku-4-5-20251001

# App Config
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=300
RATE_LIMIT_QPS=1
